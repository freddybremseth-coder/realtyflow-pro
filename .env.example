# RealtyFlow Pro uses the shared Supabase project as master.
# Do not use the old free project ref: jvcdkclfcaccogmvvkrs.

NEXT_PUBLIC_SUPABASE_URL=https://ereapsfcsqtdmzosgnnn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Olivia / Dona Anna data lives in the same Supabase project under olivia.
# Set OLIVIA_SUPABASE_URL/KEY only if Olivia moves to a separate project.
OLIVIA_SCHEMA=olivia
# OLIVIA_SUPABASE_URL=https://ereapsfcsqtdmzosgnnn.supabase.co
# OLIVIA_SUPABASE_KEY=your-supabase-service-role-or-anon-key

# Family data lives in the same Supabase project under family.
FAMILY_SCHEMA=family
# FAMILY_SUPABASE_URL=https://ereapsfcsqtdmzosgnnn.supabase.co
# FAMILY_SUPABASE_KEY=your-supabase-service-role-or-anon-key

REALTYFLOW_SESSION_SECRET=choose-a-long-random-secret

# Lead Intelligence stays disabled until each phase is reviewed and activated server-side.
REALTYFLOW_LEAD_INTELLIGENCE_ENABLED=false
REALTYFLOW_LEAD_INTELLIGENCE_PERSISTENCE_ENABLED=false
REALTYFLOW_LEAD_CONTACT_LOOKUP_HMAC_SECRET=replace-with-long-server-only-random-secret
# Required in production for Lead Intelligence persistence routes.
# Dev/test may use existing server-only DB URL fallbacks.
# Do not expose this to the browser.
# REALTYFLOW_LEAD_INTELLIGENCE_DATABASE_URL=postgresql://...
REALTYFLOW_PROPERTY_MATCHING_ENABLED=false
REALTYFLOW_AUTO_SEND_ENABLED=false
